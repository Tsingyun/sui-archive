# ===========================================================================
# SUI Archive — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git (it is in .gitignore).
#
# Load order: .env in project root → environment variables
# ===========================================================================

# ---------------------------------------------------------------------------
# Cloudflare R2 — Image Storage
# ---------------------------------------------------------------------------
# S3-compatible API credentials for R2 bucket access.
# Generate at: Cloudflare Dashboard → R2 → Manage R2 API Tokens

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sui-archive-images
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# Alternative variable names also supported:
# R2_BUCKET_NAME  (alias for R2_BUCKET)

# ---------------------------------------------------------------------------
# Cloudflare — CDN & Worker Deployment
# ---------------------------------------------------------------------------
# API token with: Workers Scripts:Write, Account Cloudflare R2:Edit
# Generate at: Cloudflare Dashboard → My Profile → API Tokens

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# Worker configuration
WORKER_NAME=sui-archive-images
WORKER_ROUTE=archive.suijisui.uk/images/*

# ---------------------------------------------------------------------------
# GitHub — Repository & Pages
# ---------------------------------------------------------------------------

GITHUB_REPOSITORY=Tsingyun/sui-archive
GITHUB_BRANCH=main

# Optional: Personal Access Token for API access (e.g., waiting for Pages build)
# GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Site Configuration (usually no need to change)
# ---------------------------------------------------------------------------

SITE_URL=https://archive.suijisui.uk
SITE_NAME=岁己 SUI Archive
